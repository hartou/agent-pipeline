{
  "$schema": "../pipeline.config.schema.json",
  "version": 1,
  "project": "your-project",
  "paths": {
    "request": "dev-agent-tasks/customer-request.md",
    "tasks": "dev-agent-tasks",
    "artifacts": "dev-agent-output"
  },
  "actors": {
    "client": {
      "role": "client",
      "runtime": "copilot",
      "authorsProductCode": false,
      "talksOnlyTo": "orchestrator",
      "responsibilities": ["intake", "qa", "acceptance", "integration"]
    },
    "orchestrator": {
      "role": "orchestrator",
      "provider": "sakana",
      "baseUrl": "https://api.sakana.ai/v1",
      "model": "fugu",
      "modelEnv": "FUGU_MODEL",
      "apiKeyEnv": "SAKANA_FUGU_API_KEY",
      "maxTokens": 12000,
      "params": { "reasoning_effort": "high" },
      "pricing": { "inputPer1M": 0, "outputPer1M": 0 }
    },
    "workers": {
      "deepseek-4-flash": {
        "role": "worker",
        "provider": "deepseek",
        "baseUrl": "https://api.deepseek.com/v1",
        "model": "deepseek-v4-flash",
        "modelEnv": "DEEPSEEK_FLASH_MODEL",
        "apiKeyEnv": "DEEPSEEK_API_KEY",
        "maxTokens": 12000,
        "params": {},
        "pricing": { "inputPer1M": 0.14, "outputPer1M": 0.28 },
        "bestFor": ["primary low-cost implementation", "fast bounded product slices", "first-pass UI/game logic"]
      },
      "deepseek-4-pro": {
        "role": "worker",
        "provider": "deepseek",
        "baseUrl": "https://api.deepseek.com/v1",
        "model": "deepseek-v4-pro",
        "modelEnv": "DEEPSEEK_MODEL",
        "apiKeyEnv": "DEEPSEEK_API_KEY",
        "maxTokens": 12000,
        "params": {},
        "pricing": { "inputPer1M": 0.435, "outputPer1M": 0.87 },
        "bestFor": ["repair after QA failure", "integration hardening", "broad multi-file scaffolding when quality matters more than minimum cost"]
      },
      "gpt-5.4-mini": {
        "role": "worker",
        "provider": "openai",
        "baseUrl": "https://api.openai.com/v1",
        "model": "gpt-5.4-mini",
        "modelEnv": "OPENAI_QA_MODEL",
        "apiKeyEnv": "OPENAI_API_KEY",
        "maxTokens": 12000,
        "params": { "reasoning_effort": "medium" },
        "pricing": { "inputPer1M": 0.75, "outputPer1M": 4.50 },
        "bestFor": ["QA/spec critic", "acceptance criteria", "test and checker generation", "edge-case review"]
      },
      "gpt-4o-mini": {
        "role": "worker",
        "provider": "openai",
        "baseUrl": "https://api.openai.com/v1",
        "model": "gpt-4o-mini",
        "modelEnv": "OPENAI_MODEL",
        "apiKeyEnv": "OPENAI_API_KEY",
        "maxTokens": 12000,
        "params": {},
        "pricing": { "inputPer1M": 0.15, "outputPer1M": 0.60 },
        "bestFor": ["i18n", "sentiment/classification", "small transformations", "lightweight text or code chores"]
      }
    }
  },
  "stackFacts": [
    "Describe your stack rules here, one fact per line, e.g. framework, build tool, conventions.",
    "State any hard rules (secrets handling, forbidden APIs, required patterns).",
    "The build worker receives these verbatim, so be precise and version-specific."
  ],
  "qa": {
    "commands": [
      { "name": "typecheck", "run": "npm run typecheck" },
      { "name": "test", "run": "npm test" },
      { "name": "smoke", "run": "npm run smoke", "requiresStack": true }
    ],
    "order": ["typecheck", "test", "smoke"]
  },
  "loop": {
    "maxRounds": 3,
    "stopOn": "qa-green",
    "maxCostUsd": 0,
    "concurrency": 3
  },
  "container": {
    "enabled": true,
    "orchestrator": true,
    "workers": true,
    "image": "agent-pipeline-runner:local",
    "dockerfile": "tools/agent-runner/Dockerfile"
  },
  "telemetry": {
    "csv": "dev-agent-context/telemetry.csv",
    "fileAuthors": "dev-agent-context/file-authorship.csv",
    "curatedCsv": "dev-agent-context/model-worker-performance.csv"
  }
}
